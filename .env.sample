RPC_URL=
# Testing purposes
DEPLOY_CONFIG=./artifacts/hoodi/deploy-hoodi.json
# Optional: utility-contract deployment JSON (e.g. artifacts/hoodi/utils/TwoPhaseFrameConfigUpdate/deploy-hoodi.json)
UTILS_DEPLOY_CONFIG=
# Specify the chain to deploy or test on
CHAIN=mainnet | hoodi
# Where to store the deployment artifacts. Default is ./artifacts/local/
ARTIFACTS_DIR=./artifacts/local/
# Optional. Upgrade tests requires this to be set to the block before the vote has been executed
VOTE_PREV_BLOCK=
